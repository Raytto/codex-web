HOST=127.0.0.1
PORT=37821
BASE_PATH=/codex-web
APP_USERNAME=owner
APP_DISPLAY_NAME=Owner
APP_PASSWORD_HASH=replace-with-bcrypt-hash
SESSION_SECRET=replace-with-at-least-32-random-bytes
SESSION_TTL_HOURS=168
PUBLIC_BASE_URL=http://localhost:37821/codex-web
# Keep the real key only in the server-side app.env file. Never commit it.
DASHSCOPE_API_KEY=
# Copy the OpenAI compatible API Host shown on the Model Studio API Key page.
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_ASR_MODEL=qwen3.5-omni-plus
# Approximate dynamic spelling/topic context budget. Audio tokens are separate.
TRANSCRIPTION_CONTEXT_TOKEN_BUDGET=500
TRANSCRIPTION_CONTEXT_MAX_IMAGES=2
TRANSCRIPTION_CONTEXT_MAX_IMAGE_BYTES=2097152
CODEX_MODEL=
CODEX_WINDOWS_SANDBOX=elevated
PYTHON_VERSION=3.12
PYTHON_RUNTIME_ROOT=
