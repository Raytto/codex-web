{
  "name": "codex-web",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web \"tsx watch server/index.ts\" \"vite --host 127.0.0.1 --port 5173\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/server/index.js",
    "hash-password": "node scripts/hash-password.mjs",
    "test": "npm run build && node --import tsx --test tests/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.144.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.3.0",
    "lucide-react": "^1.24.0",
    "multer": "^2.2.0",
    "pino": "^10.3.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "^10.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "vite": "8.1.5"
  },
  "type": "module"
}
